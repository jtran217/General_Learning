{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": ".",
        "lib": [
            "ES2022"
        ]
    },
    "include": [
        "index.ts",
        "db/**/*.ts",
        "routes/**/*.ts"
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}